{
  "name": "@mcpinsight/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.11.1"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "@vitest/coverage-v8": "1.6.1",
    "tsup": "8.2.3",
    "typescript": "5.5.3",
    "vitest": "1.6.1"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@mcpinsight/core": "workspace:*",
    "hono": "4.12.14"
  }
}
