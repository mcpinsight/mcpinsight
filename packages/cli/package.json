{
  "name": "@mcpinsight/cli",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.11.1"
  },
  "bin": {
    "mcpinsight": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcpinsight/core": "workspace:*",
    "commander": "12.1.0"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "tsup": "8.2.3",
    "typescript": "5.5.3"
  }
}
