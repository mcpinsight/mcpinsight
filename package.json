{
  "name": "mcpinsight",
  "private": true,
  "version": "0.0.0",
  "description": "Analytics for MCP servers in AI coding agents",
  "type": "module",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.11.1"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "cli": "pnpm --filter @mcpinsight/cli start",
    "test:fixtures": "pnpm --filter @mcpinsight/core test:fixtures",
    "test:e2e": "playwright test",
    "coverage": "pnpm -r coverage",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@playwright/test": "1.45.0",
    "typescript": "5.5.3"
  }
}
