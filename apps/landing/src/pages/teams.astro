---
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below
import Nav from '../components/Nav.astro';
import { copy } from '../copy/en.ts';

// biome-ignore lint/correctness/noUnusedVariables: referenced in Astro template below
const pageTitle = `${copy.teams.headline} — MCPInsight for teams`;
// biome-ignore lint/correctness/noUnusedVariables: referenced in Astro template below
const pageDescription = copy.teams.subhead;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <script is:inline defer data-domain="mcpinsight.dev" src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="min-h-screen bg-slate-50 font-sans text-slate-900 antialiased">
    <Nav />

    <main class="mx-auto max-w-3xl px-6 py-24 text-center sm:py-32">
      <p class="text-xs font-medium uppercase tracking-[0.12em] text-slate-500">
        {copy.teams.eyebrow}
      </p>
      <h1
        class="mt-3 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl"
      >
        {copy.teams.headline}
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-slate-600 sm:text-xl">
        {copy.teams.subhead}
      </p>
      <p class="mt-4 text-base text-slate-500">{copy.teams.sub}</p>
      <div class="mt-10">
        <a
          href="/#waitlist"
          class="inline-flex items-center justify-center rounded-lg bg-brand px-6 py-4 text-base font-semibold text-white shadow-sm transition hover:bg-brand-dark hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/50 focus-visible:ring-offset-2"
        >
          {copy.teams.backCta}
          <span aria-hidden="true" class="ml-1">→</span>
        </a>
      </div>
    </main>
  </body>
</html>
