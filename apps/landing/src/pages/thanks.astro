---
// biome-ignore lint/correctness/noUnusedImports: used in Astro template below
import { copy } from '../copy/en.ts';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{copy.waitlist.successHeading} — MCPInsight</title>
    <meta name="description" content={copy.waitlist.successBody} />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  </head>
  <body class="min-h-screen bg-slate-50 font-sans text-slate-900 antialiased">
    <main class="mx-auto flex min-h-screen max-w-xl flex-col items-center justify-center px-6 py-16 text-center">
      <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-8">
        <h1 class="text-2xl font-bold text-emerald-900 sm:text-3xl">
          {copy.waitlist.successHeading}
        </h1>
        <p class="mt-4 text-base text-emerald-800">{copy.waitlist.successBody}</p>
      </div>
      <a
        href="/"
        class="mt-8 inline-flex items-center justify-center rounded-md bg-brand px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-dark"
      >
        Back to home
      </a>
    </main>
  </body>
</html>
